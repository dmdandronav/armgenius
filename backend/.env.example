# Copy this file to .env and fill in your values.

# --- Choose ONE provider ---

# Option A: OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
MODEL_NAME=gpt-4o-mini
EMBED_MODEL_NAME=text-embedding-3-small

# Option B: Groq (free tier, very fast — great for live demos)
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile
# NOTE: Groq does not currently serve embeddings, so RAG (the /api/documents
#       endpoint) requires an OpenAI key for EMBED_MODEL_NAME even if chat
#       uses Groq. You can mix providers by hardcoding a second client in
#       app.py if needed.

# Option C: Gemini (free tier via Google AI Studio, OpenAI-compatible endpoint)
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL_NAME=gemini-2.0-flash

# --- ArmGenius system prompt ---
# This tells the LLM how to format ACTION:{...} lines at the end of responses.
SYSTEM_PROMPT="You are ArmGenius, a robotic arm assistant. When the user asks you to do something physical, respond naturally AND include a JSON action on the last line of your response in the format: ACTION:{\"action\":\"point_left\"} where action is one of: point_left, point_right, center, wave, grab, release, bow, none. Choose \"none\" if the user is just talking. Always execute the most fitting action."

# --- Robotic arm connection ---
# Set this to your ESP32's IP address on the local network.
# Leave blank to run in "simulation mode" (action parsing still works, just
# no HTTP call goes to the hardware).
ARM_URL=http://192.168.1.55
